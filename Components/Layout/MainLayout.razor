@inherits LayoutComponentBase

<Layout Sider="true">
    <LayoutSider>
        <LayoutSiderContent>
            <SideMenu />
        </LayoutSiderContent>
    </LayoutSider>

    <Layout>
        <LayoutHeader Fixed="true">
            <TopMenu />
        </LayoutHeader>
        <LayoutContent Padding="Padding.Is3.OnX.Is3.OnY" Background=Background.Dark TextColor=TextColor.Light>
            @Body
        </LayoutContent>
    </Layout>
</Layout>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>